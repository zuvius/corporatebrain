# Environment Variables

# Database (Required)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/corporate_brain"

# Authentication (Required) - Auth.js v5
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your-super-secret-random-string-here-min-32-chars"
AUTH_TRUST_HOST=true

# AI Providers (At least one required)
OPENAI_API_KEY="sk-your-openai-api-key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"
GOOGLE_AI_API_KEY="your-google-ai-api-key"

# Redis/Cache (Optional)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# External Services (Optional)
UNSTRUCTURED_API_KEY=""
FIRECRAWL_API_KEY=""

# OAuth - Google (Required for auth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth - Slack (Optional)
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_SIGNING_SECRET=""

# OAuth - Notion (Optional)
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""

# OAuth - Microsoft (Optional)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# OAuth - Zoom (Optional)
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""

# OAuth - GitHub (Optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# OAuth - Salesforce (Optional)
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""
